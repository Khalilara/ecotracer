pipeline {
    agent none

    environment {
        REPO_URL    = 'https://github.com/Fredericsonn/ecotracer.git'
        REMOTE_USER = 'eco'
    }

    stages {

        stage('Cloning the repository') {
            agent { docker { image 'ecotracer/back-agent' } }
            steps {
                    git branch: "${ENV}", url: "${env.REPO_URL}"
                }
        }

        stage('Build (multi-module)') {
            agent { docker { image 'ecotracer/back-agent' } }
            steps {
                sh '''
                    cd backend
                    mvn -U -DskipTests clean package
                '''
            }
        }

        stage('Archive artifacts') {
            agent { docker { image 'ecotracer/back-agent' } }
            steps {
                archiveArtifacts artifacts: '''
                    backend/eco-core/target/*.jar,
                    backend/eco-auth/target/*.jar,
                    backend/eco-core/Dockerfile,
                    backend/eco-auth/Dockerfile,
                    backend/docker-compose.yml
                ''', allowEmptyArchive: false
            }
        }

        stage('Build Docker images') {
            agent {
                docker {
                    image 'ecotracer/dind'
                    args '--user root --restart always -v /var/run/docker.sock:/var/run/docker.sock --entrypoint=""'
                }
            }
            steps {
                withVault([
                    vaultSecrets: [[
                        path: "jenkins/backend/${ENV}",
                        secretValues: [
                            [envVar: 'REGISTRY_URL',    vaultKey: 'REGISTRY_URL'],
                            [envVar: 'CORE_IMAGE_NAME', vaultKey: 'CORE_IMAGE_NAME'],
                            [envVar: 'AUTH_IMAGE_NAME', vaultKey: 'AUTH_IMAGE_NAME']
                        ]
                    ]]
                ]) {
                    sh '''
                        cd backend

                        # Build eco-core
                        docker build \
                          -f eco-core/Dockerfile \
                          -t $REGISTRY_URL/$CORE_IMAGE_NAME:$BUILD_NUMBER \
                          -t $REGISTRY_URL/$CORE_IMAGE_NAME:latest \
                          .

                        # Build eco-auth
                        docker build \
                          -f eco-auth/Dockerfile \
                          -t $REGISTRY_URL/$AUTH_IMAGE_NAME:$BUILD_NUMBER \
                          -t $REGISTRY_URL/$AUTH_IMAGE_NAME:latest \
                          .
                    '''
                }
            }
        }

        stage('Push Docker images') {
            agent {
                docker {
                    image 'ecotracer/dind'
                    args '--user root --restart always -v /var/run/docker.sock:/var/run/docker.sock --entrypoint=""'
                }
            }
            steps {
                withVault([
                    vaultSecrets: [[
                        path: "jenkins/backend/${ENV}",
                        secretValues: [
                            [envVar: 'REGISTRY_URL',    vaultKey: 'REGISTRY_URL'],
                            [envVar: 'CORE_IMAGE_NAME', vaultKey: 'CORE_IMAGE_NAME'],
                            [envVar: 'AUTH_IMAGE_NAME', vaultKey: 'AUTH_IMAGE_NAME']
                        ]
                    ]]
                ]) {
                    withCredentials([
                        usernamePassword(
                            credentialsId: 'registry',
                            usernameVariable: 'USERNAME',
                            passwordVariable: 'PASSWORD'
                        )
                    ]) {
                        sh '''
                            docker login $REGISTRY_URL -u "$USERNAME" -p "$PASSWORD"

                            docker push $REGISTRY_URL/$CORE_IMAGE_NAME:$BUILD_NUMBER
                            docker push $REGISTRY_URL/$CORE_IMAGE_NAME:latest

                            docker push $REGISTRY_URL/$AUTH_IMAGE_NAME:$BUILD_NUMBER
                            docker push $REGISTRY_URL/$AUTH_IMAGE_NAME:latest
                        '''
                    }
                }
            }
        }

stage('Deploy (docker compose on remote)') {
    agent {
        docker {
            image 'ecotracer/dind'
            args '--user root --restart always -v /var/run/docker.sock:/var/run/docker.sock --entrypoint=""'
        }
    }

    steps {
        withVault([
            vaultSecrets: [[
                path: "jenkins/backend/${ENV}",
                secretValues: [
                    [envVar: 'REMOTE_HOST',       vaultKey: 'REMOTE_HOST'],
                    [envVar: 'REGISTRY_URL',      vaultKey: 'REGISTRY_URL'],

                    [envVar: 'CORE_IMAGE_NAME',   vaultKey: 'CORE_IMAGE_NAME'],
                    [envVar: 'AUTH_IMAGE_NAME',   vaultKey: 'AUTH_IMAGE_NAME'],

                    [envVar: 'VAULT_URI',         vaultKey: 'VAULT_URI'],
                    [envVar: 'VAULT_TOKEN',       vaultKey: 'VAULT_TOKEN'],
                    [envVar: 'VAULT_MOUNT',         vaultKey: 'VAULT_MOUNT'],
                    [envVar: 'VAULT_APP',       vaultKey: 'VAULT_APP'],
                ]
            ]]
        ]) {
            sshagent(['creds']) {
                sh '''
                    set -e

                    # Make sure remote directory exists and copy only compose (no .env / no secrets file)
                    ssh -o StrictHostKeyChecking=no "$REMOTE_USER@$REMOTE_HOST" "mkdir -p ~/eco-backend"
                    scp -o StrictHostKeyChecking=no backend/docker-compose.yml "$REMOTE_USER@$REMOTE_HOST:~/eco-backend/docker-compose.yml"

                    # Run compose with env vars injected only for this SSH command (nothing written on remote disk)
                    ssh -o StrictHostKeyChecking=no "$REMOTE_USER@$REMOTE_HOST" \
                      "cd ~/eco-backend && \
                       REGISTRY_URL='${REGISTRY_URL}' \
                       CORE_IMAGE_NAME='${CORE_IMAGE_NAME}' \
                       AUTH_IMAGE_NAME='${AUTH_IMAGE_NAME}' \
                       VAULT_URI='${VAULT_URI}' \
                       VAULT_TOKEN='${VAULT_TOKEN}' \
                       docker compose pull && \
                       REGISTRY_URL='${REGISTRY_URL}' \
                       CORE_IMAGE_NAME='${CORE_IMAGE_NAME}' \
                       AUTH_IMAGE_NAME='${AUTH_IMAGE_NAME}' \
                       VAULT_URI='${VAULT_URI}' \
                       VAULT_TOKEN='${VAULT_TOKEN}' \
                       VAULT_MOUNT='${VAULT_MOUNT}' \
                       VAULT_APP='${VAULT_APP}' \
                       ENV='${ENV}' \
                       docker compose up -d --remove-orphans && \
                       docker image prune -f"
                '''
            }
        }
    }
}

    }

    post {
        success { echo 'Deployment completed successfully!' }
        failure { echo 'Deployment failed. Please check the logs.' }
    }
}
