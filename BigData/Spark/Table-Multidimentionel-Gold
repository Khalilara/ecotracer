WITH hours AS (
    SELECT generate_series(0, 23) AS hour
),
dates AS (
    SELECT DISTINCT date AS date_id
    FROM {{ source('public', 'energy_gold') }}
)
SELECT
    d.date_id,
    h.hour,
    CASE
        WHEN h.hour >= 22 OR h.hour < 6 THEN 'HC'
        ELSE 'HP'
    END                                         AS tariff_type,
    CASE
        WHEN h.hour >= 22 OR h.hour < 6 THEN 0.22
        ELSE 0.38
    END                                         AS price_eur_kwh,
    0.053                                       AS co2_factor_kg_kwh,
    DATE_TRUNC('year', d.date_id)::date         AS valid_from,
    (DATE_TRUNC('year', d.date_id)
        + INTERVAL '1 year - 1 day')::date      AS valid_to
FROM dates d
CROSS JOIN hours h

