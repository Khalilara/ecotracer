SELECT
    g.date                                              AS date_id,
    g.house_id,
    a.appliance_id,
    g.daily_kwh,
    g.daily_co2_kg,
    g.hours_active,
    ROUND((g.daily_kwh * 0.38)::numeric, 4)             AS daily_cost_eur,
    CASE
        WHEN g.hours_active > 20
        THEN ROUND((g.daily_kwh - (a.expected_cost_eur / 365))::numeric, 4)
        ELSE 0
    END                                                 AS excess_kwh
FROM {{ source('public', 'energy_gold') }} g
LEFT JOIN {{ ref('dim_appliance') }} a
    ON g.machine_name = a.machine_name
    AND g.house_id = a.house_id

