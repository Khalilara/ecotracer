WITH unique_appliances AS (
    SELECT DISTINCT
        machine_name,
        house_id,
        CASE
            WHEN machine_name ILIKE '%refrigerator%' THEN 'Refrigeration'
            WHEN machine_name ILIKE '%freezer%'      THEN 'Refrigeration'
            WHEN machine_name ILIKE '%washing%'      THEN 'Washing'
            WHEN machine_name ILIKE '%dish%'         THEN 'Washing'
            WHEN machine_name ILIKE '%dryer%'        THEN 'Washing'
            WHEN machine_name ILIKE '%coffee%'       THEN 'Kitchen'
            WHEN machine_name ILIKE '%heat%'         THEN 'Heating'
            ELSE 'Other'
        END AS category
    FROM {{ source('public', 'energy_gold') }}
)
SELECT
    ROW_NUMBER() OVER (ORDER BY house_id, machine_name) AS appliance_id,
    machine_name,
    house_id,
    category,
    CASE category
        WHEN 'Refrigeration' THEN 'A+'
        WHEN 'Washing'       THEN 'A'
        WHEN 'Kitchen'       THEN 'B'
        WHEN 'Heating'       THEN 'C'
        ELSE 'D'
    END                                                  AS energy_label,
    CASE category
        WHEN 'Refrigeration' THEN 8
        WHEN 'Washing'       THEN 6
        WHEN 'Kitchen'       THEN 4
        WHEN 'Heating'       THEN 10
        ELSE 5
    END                                                  AS age_years,
    CASE category
        WHEN 'Refrigeration' THEN 150.00
        WHEN 'Washing'       THEN 200.00
        WHEN 'Kitchen'       THEN 80.00
        WHEN 'Heating'       THEN 500.00
        ELSE 100.00
    END                                                  AS expected_cost_eur,
    CASE category
        WHEN 'Refrigeration' THEN 600.00
        WHEN 'Washing'       THEN 800.00
        WHEN 'Kitchen'       THEN 300.00
        WHEN 'Heating'       THEN 2000.00
        ELSE 400.00
    END                                                  AS replace_cost_eur
FROM unique_appliances

