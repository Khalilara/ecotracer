WITH dates_houses AS (
    SELECT DISTINCT
        date    AS date_id,
        house_id
    FROM {{ source('public', 'energy_gold') }}
)
SELECT
    d.date_id,
    d.house_id,
    ROUND((15 + 10 * SIN((EXTRACT(doy FROM d.date_id) - 80) * 2 * PI() / 365))::numeric, 1) AS temp_avg_celsius,
    ROUND((10 + 10 * SIN((EXTRACT(doy FROM d.date_id) - 80) * 2 * PI() / 365))::numeric, 1) AS temp_min_celsius,
    ROUND((20 + 10 * SIN((EXTRACT(doy FROM d.date_id) - 80) * 2 * PI() / 365))::numeric, 1) AS temp_max_celsius,
    ROUND((ABS(SIN(EXTRACT(doy FROM d.date_id) * 7)) * 15)::numeric, 1)                     AS precipitation_mm,
    CASE
        WHEN EXTRACT(month FROM d.date_id) IN (11, 12, 1, 2, 3) THEN true
        ELSE false
    END                                                                                       AS isheating_season
FROM dates_houses d
